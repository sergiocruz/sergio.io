---
import { SITE } from '../config/site.ts';
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ProfilePage',
  mainEntity: {
    '@type': 'Person',
    name: SITE.author,
    url: SITE.url,
    jobTitle: 'Senior Director of Software Engineering',
    worksFor: { '@type': 'Organization', name: 'Ramsey Solutions' },
    sameAs: [SITE.social.twitter, SITE.social.github, SITE.social.linkedin],
    description: SITE.description,
  },
};
---

<BaseLayout
  title={`About - ${SITE.author}`}
  description={`Learn more about ${SITE.author}, Senior Engineering Leader with 15+ years of experience building and scaling engineering organizations.`}
  jsonLd={jsonLd}
>
  <Navigation />

  <main class="pt-16">
    <!-- Hero Section -->
    <section class="bg-brand-light dark:bg-brand-dark py-20">
      <div class="mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
        <h1
          class="text-brand-primary dark:text-brand-light mb-6 font-serif text-4xl font-semibold sm:text-5xl"
        >
          About Me
        </h1>
        <p class="text-brand-subtle mx-auto max-w-3xl text-xl dark:text-gray-300">
          Senior engineering leader who turns technical systems, engineering teams, and AI-enabled
          practices into business leverage.
        </p>
      </div>
    </section>

    <!-- About Content with Photo -->
    <section class="dark:bg-brand-primary bg-white py-20">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 items-center gap-8 lg:grid-cols-12 lg:gap-16">
          <!-- Profile Image -->
          <div class="lg:col-span-4">
            <div class="relative mx-auto max-w-48 sm:max-w-64 lg:max-w-none">
              <div class="aspect-square overflow-hidden rounded-full shadow-lg">
                <img
                  src="/images/sergiocruz-avatar.jpg"
                  alt="Sergio Cruz"
                  class="h-full w-full object-cover"
                />
              </div>
              <!-- Decorative element -->
              <div
                class="bg-brand-accent/10 absolute -right-4 -bottom-4 -z-10 h-20 w-20 rounded-full sm:h-24 sm:w-24 lg:-right-6 lg:-bottom-6 lg:h-32 lg:w-32"
              >
              </div>
            </div>
          </div>

          <!-- Content -->
          <div class="space-y-6 lg:col-span-8">
            <div class="space-y-6 text-lg leading-relaxed">
              <p class="text-brand-subtle dark:text-gray-300">
                I'm a Senior Director of Software Engineering at Ramsey Solutions, where I lead four
                cross-functional teams within a 40+ person business unit that grew 67% over three
                years. I operate at the intersection of technology, product, and business strategy —
                the kind of work where a MySQL data-quality issue becomes a multimillion-dollar
                revenue opportunity.
              </p>

              <p class="text-brand-subtle dark:text-gray-300">
                15+ years in software, from first technical hire at a startup that scaled to 8-digit
                monthly revenue, to engineering leader within a 150-person engineering organization.
                I've scaled teams from 2 to 15+ engineers, initiated data science programs that
                tripled partner profitability, and contributed to driving AI adoption across an
                entire engineering org.
              </p>

              <p class="text-brand-subtle dark:text-gray-300">
                I stay close to the craft through publishing — four Pluralsight courses on
                engineering leadership and software development (2024-2025), conference talks at
                ng-conf, and a YouTube series on engineering leadership with 45K+ views. I still
                code at home. The CTO trajectory is my north star.
              </p>
            </div>

            <!-- Quick Stats -->
            <div
              class="border-brand-subtle/20 mt-8 grid grid-cols-2 gap-6 border-t pt-8 md:grid-cols-4"
            >
              <div class="text-center">
                <div class="text-brand-primary dark:text-brand-light mb-1 text-2xl font-bold">
                  15+
                </div>
                <div class="text-brand-subtle text-sm dark:text-gray-400">Years in Software</div>
              </div>
              <div class="text-center">
                <div class="text-brand-primary dark:text-brand-light mb-1 text-2xl font-bold">
                  50+
                </div>
                <div class="text-brand-subtle text-sm dark:text-gray-400">Engineers Mentored</div>
              </div>
              <div class="text-center">
                <div class="text-brand-primary dark:text-brand-light mb-1 text-2xl font-bold">
                  15+
                </div>
                <div class="text-brand-subtle text-sm dark:text-gray-400">
                  Talks & Presentations
                </div>
              </div>
              <div class="text-center">
                <div class="text-brand-primary dark:text-brand-light mb-1 text-2xl font-bold">
                  5
                </div>
                <div class="text-brand-subtle text-sm dark:text-gray-400">Published Courses</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Core Expertise -->
    <section class="bg-brand-light dark:bg-brand-dark py-20">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <div class="mb-16 text-center">
          <h2
            class="text-brand-primary dark:text-brand-light mb-4 font-serif text-3xl font-semibold"
          >
            What I Do Best
          </h2>
          <p class="text-brand-subtle mx-auto max-w-2xl text-lg dark:text-gray-300">
            Three core areas where I focus my energy and create the most impact.
          </p>
        </div>

        <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
          <div
            class="border-brand-subtle/20 dark:bg-brand-primary rounded-xl border bg-white p-8 text-center shadow-sm transition-shadow hover:shadow-md"
          >
            <div
              class="bg-brand-accent/20 mx-auto mb-6 flex h-16 w-16 items-center justify-center rounded-xl"
            >
              <svg
                class="text-brand-accent h-8 w-8"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"
                ></path>
              </svg>
            </div>
            <h3
              class="text-brand-primary dark:text-brand-light mb-4 font-serif text-xl font-semibold"
            >
              Business-Technical Integration
            </h3>
            <p class="text-brand-subtle dark:text-gray-300">
              I find revenue leverage in technical work. My teams surface business insights,
              identify mispriced programs, and turn data infrastructure into competitive advantages.
            </p>
          </div>

          <div
            class="border-brand-subtle/20 dark:bg-brand-primary rounded-xl border bg-white p-8 text-center shadow-sm transition-shadow hover:shadow-md"
          >
            <div
              class="bg-brand-accent/20 mx-auto mb-6 flex h-16 w-16 items-center justify-center rounded-xl"
            >
              <svg
                class="text-brand-accent h-8 w-8"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9.663 17h4.673M12 3v1m6.364-.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"
                ></path>
              </svg>
            </div>
            <h3
              class="text-brand-primary dark:text-brand-light mb-4 font-serif text-xl font-semibold"
            >
              Engineering Org Leadership
            </h3>
            <p class="text-brand-subtle dark:text-gray-300">
              Scaled engineering organizations from 2 to 15+ engineers. Built management layers,
              designed career growth tracks adopted org-wide, and contributed to AI tooling adoption
              across 150+ engineers.
            </p>
          </div>

          <div
            class="border-brand-subtle/20 dark:bg-brand-primary rounded-xl border bg-white p-8 text-center shadow-sm transition-shadow hover:shadow-md"
          >
            <div
              class="bg-brand-accent/20 mx-auto mb-6 flex h-16 w-16 items-center justify-center rounded-xl"
            >
              <svg
                class="text-brand-accent h-8 w-8"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"
                ></path>
              </svg>
            </div>
            <h3
              class="text-brand-primary dark:text-brand-light mb-4 font-serif text-xl font-semibold"
            >
              Cross-Functional Strategy
            </h3>
            <p class="text-brand-subtle dark:text-gray-300">
              I operate at the business leadership table using EOS and OKRs. My teams track business
              metrics and leading indicators, not just output. I partner across product, marketing,
              and operations to tie engineering work to revenue outcomes.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Professional Journey -->
    <section class="dark:bg-brand-primary bg-white py-20">
      <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
        <div class="mb-16 text-center">
          <h2
            class="text-brand-primary dark:text-brand-light mb-4 font-serif text-3xl font-semibold"
          >
            Professional Journey
          </h2>
          <p class="text-brand-subtle text-lg dark:text-gray-300">
            Key milestones in my career and the impact I've made along the way.
          </p>
        </div>

        <div class="space-y-12">
          <!-- Experience Item -->
          <div class="border-brand-accent/30 dark:border-brand-accent/50 relative border-l-2 pl-8">
            <div class="bg-brand-accent absolute top-0 -left-2 h-4 w-4 rounded-full"></div>
            <div
              class="border-brand-subtle/20 bg-brand-light dark:bg-brand-dark rounded-lg border p-6 shadow-sm"
            >
              <div class="mb-4 flex flex-col sm:flex-row sm:items-center sm:justify-between">
                <h3
                  class="text-brand-primary dark:text-brand-light font-serif text-xl font-semibold"
                >
                  Senior Director of Software Engineering
                </h3>
                <span class="text-sm text-gray-500 dark:text-gray-400">2024 - Present</span>
              </div>
              <p class="text-brand-accent dark:text-brand-accent mb-3 font-medium">
                Ramsey Solutions
              </p>
              <p class="text-brand-subtle mb-4 dark:text-gray-300">
                Engineering leader across four cross-functional teams within a 40+ person business
                unit. Identified a MySQL casting error that masked partner profitability in a
                financial reporting pipeline; partnered with business leadership to reprice the
                program, creating a projected multimillion-dollar annual revenue opportunity. Led a
                multi-year data science initiative that increased partner close rates 60% and
                tripled profitability. Part of the leadership team driving company-wide AI tooling
                adoption across 150+ engineers.
              </p>
              <div class="flex flex-wrap gap-2">
                <span class="bg-brand-accent/20 text-brand-accent rounded-full px-3 py-1 text-sm"
                  >Business Impact</span
                >
                <span class="bg-brand-accent/20 text-brand-accent rounded-full px-3 py-1 text-sm"
                  >Data Science</span
                >
                <span class="bg-brand-accent/20 text-brand-accent rounded-full px-3 py-1 text-sm"
                  >AI Adoption</span
                >
              </div>
            </div>
          </div>

          <!-- Experience Item -->
          <div class="border-brand-accent/30 dark:border-brand-accent/50 relative border-l-2 pl-8">
            <div class="bg-brand-accent absolute top-0 -left-2 h-4 w-4 rounded-full"></div>
            <div
              class="border-brand-subtle/20 bg-brand-light dark:bg-brand-dark rounded-lg border p-6 shadow-sm"
            >
              <div class="mb-4 flex flex-col sm:flex-row sm:items-center sm:justify-between">
                <h3
                  class="text-brand-primary dark:text-brand-light font-serif text-xl font-semibold"
                >
                  Director of Software Engineering
                </h3>
                <span class="text-sm text-gray-500 dark:text-gray-400">2021 - 2024</span>
              </div>
              <p class="text-brand-accent dark:text-brand-accent mb-3 font-medium">
                Ramsey Solutions
              </p>
              <p class="text-brand-subtle mb-4 dark:text-gray-300">
                Scaled the engineering organization from 5 to 15+ engineers and leaders within a 40+
                person cross-functional business unit. Owned integration platform strategy,
                architecting partner data integrations connecting customers to mortgage, insurance,
                and financial providers. Sat at the BU leadership table using EOS and OKRs; drove
                standardization of CI/CD, testing, and architecture across multiple squads.
              </p>
              <div class="flex flex-wrap gap-2">
                <span class="bg-brand-accent/20 text-brand-accent rounded-full px-3 py-1 text-sm"
                  >Team Scaling</span
                >
                <span class="bg-brand-accent/20 text-brand-accent rounded-full px-3 py-1 text-sm"
                  >Integration Architecture</span
                >
                <span class="bg-brand-accent/20 text-brand-accent rounded-full px-3 py-1 text-sm"
                  >OKRs</span
                >
              </div>
            </div>
          </div>

          <!-- Experience Item -->
          <div class="border-brand-accent/30 dark:border-brand-accent/50 relative border-l-2 pl-8">
            <div class="bg-brand-accent absolute top-0 -left-2 h-4 w-4 rounded-full"></div>
            <div
              class="border-brand-subtle/20 bg-brand-light dark:bg-brand-dark rounded-lg border p-6 shadow-sm"
            >
              <div class="mb-4 flex flex-col sm:flex-row sm:items-center sm:justify-between">
                <h3
                  class="text-brand-primary dark:text-brand-light font-serif text-xl font-semibold"
                >
                  Engineering Manager
                </h3>
                <span class="text-sm text-gray-500 dark:text-gray-400">2017 - 2019</span>
              </div>
              <p class="text-brand-accent dark:text-brand-accent mb-3 font-medium">
                Trazi Ventures
              </p>
              <p class="text-brand-subtle mb-4 dark:text-gray-300">
                First technical hire building consumer-facing app. Scaled product to handle 7-digit
                monthly signups and 8-digit revenue. Hired and mentored technical team.
              </p>
              <div class="flex flex-wrap gap-2">
                <span class="bg-brand-accent/20 text-brand-accent rounded-full px-3 py-1 text-sm"
                  >Startup Experience</span
                >
                <span class="bg-brand-accent/20 text-brand-accent rounded-full px-3 py-1 text-sm"
                  >High Scale</span
                >
                <span class="bg-brand-accent/20 text-brand-accent rounded-full px-3 py-1 text-sm"
                  >Team Building</span
                >
              </div>
            </div>
          </div>
        </div>

        <div class="mt-12 text-center">
          <a
            href="/resume"
            class="border-brand-subtle text-brand-primary hover:bg-brand-subtle/10 focus:ring-brand-accent dark:text-brand-light inline-flex items-center rounded-md border bg-transparent px-6 py-3 text-base font-medium transition-colors focus:ring-2 focus:ring-offset-2 focus:outline-none"
          >
            View Full Resume
            <svg class="ml-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </a>
        </div>
      </div>
    </section>

    <!-- Leadership Philosophy -->
    <section class="bg-brand-light dark:bg-brand-dark py-20">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <div class="mb-16 text-center">
          <h2
            class="text-brand-primary dark:text-brand-light mb-4 font-serif text-3xl font-semibold"
          >
            My Leadership Philosophy
          </h2>
          <p class="text-brand-subtle mx-auto max-w-2xl text-lg dark:text-gray-300">
            The principles that guide how I approach engineering leadership and team building.
          </p>
        </div>

        <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
          <div
            class="border-brand-subtle/20 dark:bg-brand-primary rounded-xl border bg-white p-8 shadow-sm"
          >
            <div
              class="bg-brand-accent/20 mb-6 flex h-12 w-12 items-center justify-center rounded-lg"
            >
              <svg
                class="text-brand-accent h-6 w-6"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"
                ></path>
              </svg>
            </div>
            <h3
              class="text-brand-primary dark:text-brand-light mb-4 font-serif text-xl font-semibold"
            >
              Shared Ownership
            </h3>
            <p class="text-brand-subtle dark:text-gray-300">
              The best teams are built on trust, not control. I empower people to take real
              ownership of their work. Whether engineers owning quality or managers owning outcomes.
            </p>
          </div>

          <div
            class="border-brand-subtle/20 dark:bg-brand-primary rounded-xl border bg-white p-8 shadow-sm"
          >
            <div
              class="bg-brand-accent/20 mb-6 flex h-12 w-12 items-center justify-center rounded-lg"
            >
              <svg
                class="text-brand-accent h-6 w-6"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <h3
              class="text-brand-primary dark:text-brand-light mb-4 font-serif text-xl font-semibold"
            >
              Craft with Purpose
            </h3>
            <p class="text-brand-subtle dark:text-gray-300">
              I care deeply about building things well and hold a high bar for code quality and
              system design. Not for perfectionism, but because the craft matters for long-term
              success.
            </p>
          </div>

          <div
            class="border-brand-subtle/20 dark:bg-brand-primary rounded-xl border bg-white p-8 shadow-sm"
          >
            <div
              class="bg-brand-accent/20 mb-6 flex h-12 w-12 items-center justify-center rounded-lg"
            >
              <svg
                class="text-brand-accent h-6 w-6"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M13 10V3L4 14h7v7l9-11h-7z"></path>
              </svg>
            </div>
            <h3
              class="text-brand-primary dark:text-brand-light mb-4 font-serif text-xl font-semibold"
            >
              Cross-Functional Partnership
            </h3>
            <p class="text-brand-subtle dark:text-gray-300">
              Great products come from strong collaboration. I work to break down silos so
              engineering, product, and design solve problems together from the start.
            </p>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
