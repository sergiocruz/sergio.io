---
import { SITE } from '../config/site.ts';
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title={`Contact - ${SITE.author}`}
  description={`Get in touch with ${SITE.author} for speaking opportunities, mentoring, or collaboration.`}
>
  <Navigation />

  <main class="pt-16">
    <!-- Hero Section -->
    <section class="bg-brand-light dark:bg-brand-dark py-24">
      <div class="mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
        <h1
          class="text-brand-primary dark:text-brand-light mb-6 font-serif text-4xl font-semibold sm:text-5xl"
        >
          Get In Touch
        </h1>
        <p class="text-brand-subtle mx-auto max-w-2xl text-xl dark:text-gray-300">
          Open to conversations about speaking engagements, mentoring, and collaboration.
        </p>
      </div>
    </section>

    <!-- Contact Content -->
    <section class="dark:bg-brand-primary bg-white py-20">
      <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 gap-12 lg:grid-cols-2">
          <!-- Direct Contact -->
          <div>
            <h2
              class="text-brand-primary dark:text-brand-light mb-8 font-serif text-2xl font-semibold"
            >
              Reach me directly
            </h2>

            <div class="space-y-8">
              <!-- Email -->
              <div class="flex items-start">
                <div
                  class="bg-brand-accent/20 flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-lg"
                >
                  <svg
                    class="text-brand-accent h-6 w-6"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                    ></path>
                  </svg>
                </div>
                <div class="ml-4">
                  <h3
                    class="text-brand-primary dark:text-brand-light font-serif text-lg font-semibold"
                  >
                    Email
                  </h3>
                  <a
                    id="email-link"
                    href="#"
                    class="text-brand-link hover:text-accent-blue text-lg transition-colors dark:text-blue-400 dark:hover:text-blue-300"
                    data-ph-capture-true
                    data-ph-name="contact-email"
                  >
                    hi[at]sergio.io
                  </a>
                </div>
              </div>

              <!-- Phone -->
              <div class="flex items-start">
                <div
                  class="bg-brand-accent/20 flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-lg"
                >
                  <svg
                    class="text-brand-accent h-6 w-6"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                    ></path>
                  </svg>
                </div>
                <div class="ml-4">
                  <h3
                    class="text-brand-primary dark:text-brand-light font-serif text-lg font-semibold"
                  >
                    Phone
                  </h3>
                  <a
                    id="phone-link"
                    href="#"
                    class="text-brand-link hover:text-accent-blue text-lg transition-colors dark:text-blue-400 dark:hover:text-blue-300"
                    data-ph-capture-true
                    data-ph-name="contact-phone"
                  >
                    407-six-nine-four-8175
                  </a>
                </div>
              </div>

              <!-- LinkedIn -->
              <div class="flex items-start">
                <div
                  class="bg-brand-accent/20 flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-lg"
                >
                  <svg class="text-brand-accent h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
                    <path
                      fill-rule="evenodd"
                      d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                      clip-rule="evenodd"></path>
                  </svg>
                </div>
                <div class="ml-4">
                  <h3
                    class="text-brand-primary dark:text-brand-light font-serif text-lg font-semibold"
                  >
                    LinkedIn
                  </h3>
                  <a
                    href={SITE.social.linkedin}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-brand-link hover:text-accent-blue text-lg transition-colors dark:text-blue-400 dark:hover:text-blue-300"
                    data-ph-capture-true
                    data-ph-name="contact-linkedin"
                  >
                    linkedin.com/in/sergiorlcruz
                  </a>
                </div>
              </div>

              <!-- Twitter/X -->
              <div class="flex items-start">
                <div
                  class="bg-brand-accent/20 flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-lg"
                >
                  <svg class="text-brand-accent h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
                    <path
                      d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
                    ></path>
                  </svg>
                </div>
                <div class="ml-4">
                  <h3
                    class="text-brand-primary dark:text-brand-light font-serif text-lg font-semibold"
                  >
                    X (Twitter)
                  </h3>
                  <a
                    href={SITE.social.twitter}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-brand-link hover:text-accent-blue text-lg transition-colors dark:text-blue-400 dark:hover:text-blue-300"
                    data-ph-capture-true
                    data-ph-name="contact-twitter"
                  >
                    @hashtagserg
                  </a>
                </div>
              </div>
            </div>
          </div>

          <!-- What I'm open to -->
          <div>
            <h2
              class="text-brand-primary dark:text-brand-light mb-8 font-serif text-2xl font-semibold"
            >
              What I'm open to
            </h2>

            <div class="text-brand-subtle space-y-4 text-lg leading-relaxed dark:text-gray-300">
              <p>
                I enjoy conversations about engineering leadership, building teams, and how
                technology creates business outcomes.
              </p>
              <p>
                Whether it's a speaking engagement, a consulting project, mentoring, or just
                exchanging ideas, I'm happy to connect.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />

  <script is:inline>
    document.addEventListener('DOMContentLoaded', function () {
      var e = document.getElementById('email-link');
      var p = document.getElementById('phone-link');
      if (e) e.href = ['mai', 'lto:', 'hi', '@', 'sergio', '.io'].join('');
      if (p) p.href = ['te', 'l:+1', '407', '694', '8175'].join('');
    });
  </script>
</BaseLayout>
